{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd /Users/tiffanyphan/code/workout-project && git config core.hooksPath .githooks"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git push*)",
            "command": "cd /Users/tiffanyphan/code/workout-project && npm test && npm run build --webpack",
            "timeout": 180,
            "statusMessage": "Running tests and build before push…"
          }
        ]
      }
    ]
  }
}
